{
  "info": {
    "name": "E-commerce API - Error Testing",
    "description": "Collezione per testare tutti gli status HTTP di errore",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "400 - Bad Request",
      "item": [
        {
          "name": "Missing Parameter in Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "401 - Unauthorized",
      "item": [
        {
          "name": "Access Protected Resource Without Token",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/cart"
          },
          "response": []
        },
        {
          "name": "Invalid Credentials",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"wrong@example.com\",\n    \"password\": \"wrongpassword\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "403 - Forbidden",
      "item": [
        {
          "name": "Non-Admin Access to Admin Resource",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{user_token}}",
                "description": "Usa il token di un utente normale (non admin)"
              }
            ],
            "url": "{{base_url}}/api/admin/stats"
          },
          "response": []
        }
      ]
    },
    {
      "name": "404 - Not Found",
      "item": [
        {
          "name": "Non-existent Product",
          "request": {
            "method": "GET",
            "header": [],
            "url": "{{base_url}}/api/products/nonexistent_id_12345"
          },
          "response": []
        },
        {
          "name": "Non-existent Order",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{admin_token}}"
              }
            ],
            "url": "{{base_url}}/api/admin/orders/99999"
          },
          "response": []
        }
      ]
    },
    {
      "name": "422 - Unprocessable Entity",
      "item": [
        {
          "name": "Invalid Email in Registration",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"invalid-email\",\n    \"password\": \"123\",\n    \"password_confirmation\": \"123\",\n    \"first_name\": \"\",\n    \"last_name\": \"\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Password Too Short",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"test@example.com\",\n    \"password\": \"12\",\n    \"password_confirmation\": \"12\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"User\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        },
        {
          "name": "Missing Required Fields",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"test@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    },
    {
      "name": "Helper - Get User Token",
      "item": [
        {
          "name": "Register Normal User",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var jsonData = pm.response.json();",
                  "pm.collectionVariables.set(\"user_token\", jsonData.token);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"user\": {\n    \"email\": \"testuser{{$randomInt}}@example.com\",\n    \"password\": \"password123\",\n    \"password_confirmation\": \"password123\",\n    \"first_name\": \"Test\",\n    \"last_name\": \"User\"\n  }\n}",
              "options": {
                "raw": {
                  "language": "json"
                }
              }
            }
          },
          "response": []
        }
      ]
    }
  ]
}
